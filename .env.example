# OpenAI-compatible API settings.
OPENAI_API_KEY=
OPENAI_API_BASE=
PROTEIN_AGENT_MODEL=
OPENALEX_API_KEY=

# Optional run controls.
PROTEIN_AGENT_MAX_LLM_CALLS=80
PROTEIN_AGENT_MAX_TOOL_CALLS=80
PROTEIN_AGENT_MAX_WALL_MS=10800000
PROTEIN_AGENT_MAX_INPUT_TOKENS=128000
PROTEIN_AGENT_MAX_OUTPUT_TOKENS=65536

# How many bootstrap-agent attempts before giving up and writing
# mode=bootstrap_failed audit log (default 2).
PROTEIN_AGENT_BOOTSTRAP_MAX_ATTEMPTS=2

# Override which Python interpreter runs solver_pkg/cli.py. Leave empty to
# auto-detect: prefer system python with torch/biotite/esm/etc. (Docker image
# scenario), fall back to the project .venv. See runtime/solver_env.py.
PROTEIN_AGENT_SOLVER_PYTHON=

